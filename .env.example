# Database — choose one:
# Local SQLite (default, dev)
DATABASE_URL=file:./trainr.db
# Turso (hosted libSQL, recommended for production)
# DATABASE_URL=libsql://your-db-name.turso.io?authToken=your-auth-token
# Postgres (Neon, Supabase, Railway)
# DATABASE_URL=postgres://user:pass@host:5432/trainr

# AI coaching (optional — app functions without it)
ANTHROPIC_API_KEY=sk-ant-...

# MCP server
MCP_TRANSPORT=stdio          # 'stdio' (local) or 'http' (hosted)
MCP_PORT=3000                # Only used when MCP_TRANSPORT=http
TRAINR_API_KEY=your-secret   # Required when MCP_TRANSPORT=http
